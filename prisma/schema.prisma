generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("user") // user, admin
  plan      String   @default("free") // free, pro, premium
  credits   Int      @default(5)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
  payments Payment[]
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  title       String
  niche       String?
  status      String   @default("draft") // draft, generating, completed, published
  creditsUsed Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ideas   Idea[]
  scripts Script[]
  videos  Video[]
  thumbnails Thumbnail[]
  posts   Post[]

  @@index([userId])
}

model Idea {
  id            String   @id @default(cuid())
  projectId     String?
  title         String
  hook          String
  contentAngle  String
  targetEmotion String
  viralScore    Int
  niche         String
  isSelected    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Script {
  id          String   @id @default(cuid())
  projectId   String
  ideaId      String?
  title       String
  hook        String
  mainContent String
  cta         String
  style       String   // storytelling, controversial, educational, emotional
  tone        String   // serious, funny, dark, energetic
  duration    String   @default("30-60")
  fullScript  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  videos  Video[]

  @@index([projectId])
}

model Video {
  id          String   @id @default(cuid())
  projectId   String
  scriptId    String?
  status      String   @default("pending") // pending, processing, completed, failed
  url         String?
  duration    Int?
  format      String   @default("short")   // short, long
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  script  Script?  @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

model Thumbnail {
  id        String   @id @default(cuid())
  projectId String
  url       String?
  prompt    String?
  style     String   // clickbait, clean, minimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Post {
  id          String    @id @default(cuid())
  projectId   String
  platform    String    // youtube, tiktok, instagram
  title       String
  description String?
  hashtags    String?
  status      String    @default("draft") // draft, scheduled, published
  scheduledAt DateTime?
  publishedAt DateTime?
  videoUrl    String?
  thumbnailUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Payment {
  id           String   @id @default(cuid())
  userId       String
  amount       Float
  method       String   // qris, bank_transfer, ewallet
  creditsAdded Int
  status       String   @default("pending") // pending, success, failed
  txId         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
